# site/ Next.js env template
# Copy to site/.env and fill values

NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=
NEXT_PUBLIC_STACK_BASE_URL=https://api.stack-auth.com

NEXT_PUBLIC_CONVEX_URL=

# Optional cloud API override for the dashboard token minting route.
# Defaults to https://envsync.adityamer.dev when unset.
ENVSYNC_CLOUD_URL=

# Optional local dev override for cloud auth in /api/cli-token.
# When set (and NODE_ENV != production), this token is used for upstream cloud calls.
ENVSYNC_CLOUD_DEV_TOKEN=
