# EnvSync environment template (current essentials)
# Copy to `.env` (or export vars in your shell) and fill what you need.

# -----------------------------------------------------------------------------
# CLI / Core
# -----------------------------------------------------------------------------
# Recovery phrase for non-interactive use (prefer keychain/session when possible)
ENVSYNC_RECOVERY_PHRASE=

# Optional actor identity override for audit metadata
ENVSYNC_ACTOR=

# Remote mode: file | cloud
ENVSYNC_REMOTE_MODE=cloud

# Cloud CLI settings
ENVSYNC_CLOUD_URL=http://127.0.0.1:8081
ENVSYNC_CLOUD_ACCESS_TOKEN=

# Remote retry/backoff tuning
ENVSYNC_REMOTE_RETRY_MAX_ATTEMPTS=3
ENVSYNC_REMOTE_RETRY_BASE_DELAY=200ms
ENVSYNC_REMOTE_RETRY_MAX_DELAY=2s

# Audit log retention/rotation
ENVSYNC_AUDIT_MAX_BYTES=1048576
ENVSYNC_AUDIT_MAX_FILES=5
ENVSYNC_AUDIT_RETENTION_DAYS=30
ENVSYNC_AUDIT_ROTATE_INTERVAL=24h

# -----------------------------------------------------------------------------
# envsync-cloud (managed cloud API)
# -----------------------------------------------------------------------------
ENVSYNC_CLOUD_ADDR=:8081

# Set true for local memory mode, false for Postgres mode
ENVSYNC_CLOUD_INMEMORY=true
ENVSYNC_CLOUD_DATABASE_URL=postgresql://envsync@localhost:5432/envsync?sslmode=disable

# PAT + auth config
ENVSYNC_CLOUD_PAT_PEPPER=
ENVSYNC_CLOUD_DEV_TOKEN=
ENVSYNC_CLOUD_JWT_ISSUER=
ENVSYNC_CLOUD_JWT_AUDIENCE=
ENVSYNC_CLOUD_JWT_SKIP_AUD_CHECK=false

# API limits
ENVSYNC_CLOUD_MAX_BODY_BYTES=1048576
ENVSYNC_CLOUD_RATE_LIMIT_RPM=240
ENVSYNC_CLOUD_RATE_LIMIT_BURST=40

# -----------------------------------------------------------------------------
# envsync-server (self-host HTTP backend)
# -----------------------------------------------------------------------------
ENVSYNC_SERVER_ADDR=:8080
ENVSYNC_SERVER_STORE=./remote_store.json
ENVSYNC_SERVER_TOKEN=

# Auth mode: token | header | token_or_header
ENVSYNC_SERVER_AUTH_MODE=token
ENVSYNC_SERVER_AUTH_HEADER=X-Auth-Request-User
ENVSYNC_SERVER_AUTH_PROXY_SECRET=

# Rate limit (0 disables)
ENVSYNC_SERVER_RATE_LIMIT_RPM=240
ENVSYNC_SERVER_RATE_LIMIT_BURST=40

# -----------------------------------------------------------------------------
# site/ env template location
# -----------------------------------------------------------------------------
# Site runtime variables are kept in site/env.example

# -----------------------------------------------------------------------------
# Terminal behavior (optional)
# -----------------------------------------------------------------------------
NO_COLOR=